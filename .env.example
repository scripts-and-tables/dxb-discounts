# Copy this file to .env and fill in values for local development.

# REQUIRED
SECRET_KEY=replace-me-with-a-long-random-string

# OPTIONAL (defaults shown)
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# DATABASE_URL is optional locally; if unset, SQLite (db.sqlite3) is used.
# On Railway this is injected automatically when the Postgres plugin is attached.
# DATABASE_URL=postgres://user:pass@host:5432/dbname
