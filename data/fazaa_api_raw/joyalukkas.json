{"id":"eea25b32-6f21-4887-8f45-47f7dd973016","offerInternalName":"Joyalukkas","offerOrder":0,"offerFeatured":0,"offerImageUri":"/upload/offers/joyalukkas-1621931470875.jpg","discount":"15","discountType":"PERCENTAGE","offerExpiry":"2026-05-27T20:00:00Z","offerStatus":2,"offerSlug":"joyalukkas","autoRenew":true,"localData":{"ar":{"description":"\u003cp class=\"ql-align-right ql-direction-rtl\"\u003eالشروط والأحكام :\u003c/p\u003e\u003cp class=\"ql-align-right ql-direction-rtl\"\u003e.\u0026nbsp;\u0026nbsp;هذا العرض حصري لحاملي بطاقة فزعه في دولة الامارة العربية المتحدة .\u003c/p\u003e\u003cp class=\"ql-align-right ql-direction-rtl\"\u003e.\u0026nbsp;\u0026nbsp;ذكر عرض الخصم من سعر بطاقة المنتج .\u003c/p\u003e\u003cp class=\"ql-align-right ql-direction-rtl\"\u003e.\u0026nbsp;لا يتزامن العرض مع أي خصومات إضافية لمتجر آخر، قسائم الخصم ، العروض الترويجية الأخرى أو أي عروض ترويجية خاصة تعمل في المتجر.\u003c/p\u003e\u003cp class=\"ql-align-right ql-direction-rtl\"\u003e.\u0026nbsp;يجب الاستفادة من العرض في وقت الشراء مقابل فاتورة واحدة فقط.\u003c/p\u003e\u003cp class=\"ql-align-right ql-direction-rtl\"\u003e.\u0026nbsp;\u0026nbsp;يجب على العملاء إبراز بطاقة فزعة الصالحة في أي محل\u0026nbsp;من جويالوكاس في الإمارات العربية المتحدة للاستفادة من العرض\u003c/p\u003e\u003cp class=\"ql-align-right ql-direction-rtl\"\u003e.\u0026nbsp;لا يمكن استرداد العرض نقدًا أو أي جزء منه.\u003c/p\u003e\u003cp class=\"ql-align-right ql-direction-rtl\"\u003e.\u0026nbsp;\u0026nbsp;لا يسر العرض على\u0026nbsp;العملات الذهبية\u0026nbsp;عيار22، والسبائك الذهبية ، ومنتجات الذهب عيار 24\u0026nbsp;وألماس الفضفاض او اي مواد ترويجية(مجوهرات ذهب/ احجار الثمينة/ألماس )\u003c/p\u003e\u003cp class=\"ql-align-right ql-direction-rtl\"\u003e.\u0026nbsp;\u0026nbsp;تحفظ\u0026nbsp;مجوهرات جوي الوكاس ال ال سى بالحق\u0026nbsp;في اتخاذ قرار نهائي في حالة ظهور اي\u0026nbsp;تعارض .\u003c/p\u003e\u003cp class=\"ql-align-right ql-direction-rtl\"\u003eالموقع وأرقام التواصل:\u003c/p\u003e\u003cp class=\"ql-align-right ql-direction-rtl\"\u003eجوي الوكاس، (محل الأول) مركز الذهب، ديرة،\u003c/p\u003e\u003cp class=\"ql-align-right ql-direction-rtl\"\u003e042253646\u003c/p\u003e\u003cp class=\"ql-align-right ql-direction-rtl\"\u003eجوي الوكاس، (فرع 1) مركز الذهب، ديرة\u003c/p\u003e\u003cp class=\"ql-align-right ql-direction-rtl\"\u003e042260930\u003c/p\u003e\u003cp class=\"ql-align-right ql-direction-rtl\"\u003eجوي الوكاس، (فرع 2) مركز الذهب، ديرة\u003c/p\u003e\u003cp class=\"ql-align-right ql-direction-rtl\"\u003e042290721\u003c/p\u003e\u003cp class=\"ql-align-right ql-direction-rtl\"\u003eجوي الوكاس، (بناية فندق صن سيتي)، شارع الفهيدي، بردبي\u003c/p\u003e\u003cp class=\"ql-align-right ql-direction-rtl\"\u003e043537732\u003c/p\u003e\u003cp class=\"ql-align-right ql-direction-rtl\"\u003eجوي الوكاس، شارع الفهيدي، بردبي\u003c/p\u003e\u003cp class=\"ql-align-right ql-direction-rtl\"\u003e043540250\u003c/p\u003e\u003cp class=\"ql-align-right ql-direction-rtl\"\u003eجوي الوكاس، مركز الكرامة، الكرامة\u003c/p\u003e\u003cp class=\"ql-align-right ql-direction-rtl\"\u003e043379183\u003c/p\u003e\u003cp class=\"ql-align-right ql-direction-rtl\"\u003eجوي الوكاس، لولو هايبرماركت، القصيص\u003c/p\u003e\u003cp class=\"ql-align-right ql-direction-rtl\"\u003e042988551\u003c/p\u003e\u003cp class=\"ql-align-right ql-direction-rtl\"\u003eجوي الوكاس، 240 شارع دمشق، القصيص الثاني\u003c/p\u003e\u003cp class=\"ql-align-right ql-direction-rtl\"\u003e042276575\u003c/p\u003e\u003cp class=\"ql-align-right ql-direction-rtl\"\u003eجوي الوكاس، لولو هايبرماركت، المستوي 2، البرشاء\u003c/p\u003e\u003cp class=\"ql-align-right ql-direction-rtl\"\u003e043234801\u0026nbsp;\u003c/p\u003e\u003cp class=\"ql-align-right ql-direction-rtl\"\u003eجوي الوكاس، مركز الذهب، اليرموك، الشارقة\u003c/p\u003e\u003cp class=\"ql-align-right ql-direction-rtl\"\u003e065660871\u003c/p\u003e\u003cp class=\"ql-align-right ql-direction-rtl\"\u003eجوي الوكاس، سوق المركزي (سوق الأزرق)\u003c/p\u003e\u003cp class=\"ql-align-right ql-direction-rtl\"\u003eال